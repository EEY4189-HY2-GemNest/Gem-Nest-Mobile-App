# Stripe Keys Template - COPY TO .env.local AND FILL WITH YOUR ACTUAL KEYS
# DO NOT COMMIT .env.local FILE - IT CONTAINS SENSITIVE DATA

# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_test_YOUR_WEBHOOK_SECRET_HERE

# Stripe Publishable Key - Safe to expose (public key)
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
BACKEND_URL=https://your-backend-url.com

# ===== Email Service Configuration =====
# SMTP Settings (Gmail, SendGrid, Mailgun, etc.)
# For Gmail: Use App Password (not regular password)
#   - Go to https://myaccount.google.com/apppasswords
#   - Generate an app password for "Mail"
# For SendGrid: Use api key as password, "apikey" as user
# For Mailgun: Use SMTP credentials from Mailgun dashboard

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
EMAIL_FROM=GemNest <noreply@gemnest.com>

# Admin email to receive seller registration notifications
ADMIN_EMAIL=admin@gemnest.com

